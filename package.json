{
  "name": "@stratchai/indicators",
  "version": "0.4.0",
  "description": "Technical indicators for systematic trading — 37 scalar-latest functions + 12 series variants for backtesting. Zero dependencies, pure functions.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build && npm test",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.[jt]s"
    ]
  },
  "keywords": [
    "indicators",
    "technical-analysis",
    "trading",
    "algotrading",
    "systematic-trading",
    "bollinger-bands",
    "macd",
    "rsi",
    "adx",
    "supertrend",
    "ichimoku",
    "candle-patterns",
    "stratchai"
  ],
  "author": "brady house",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stratchai/indicators.git"
  },
  "bugs": {
    "url": "https://github.com/stratchai/indicators/issues"
  },
  "homepage": "https://github.com/stratchai/indicators#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.41",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  }
}
